# ─── 裸机开发环境配置（非 Docker）─────────────────────────────────────────────
# 把本文件复制为 .env 并填写实际值

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=mysql+aiomysql://root:your_password@localhost:3306/ai_clip

# ─── Redis ────────────────────────────────────────────────────────────────────
# 裸机运行用 localhost，Docker Compose 用 redis
REDIS_URL=redis://localhost:6379/0

# ─── MinIO ────────────────────────────────────────────────────────────────────
# 裸机运行用 localhost，Docker Compose 用 minio
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=ai-clip
MINIO_SECURE=false

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production
JWT_EXPIRE_HOURS=24

# ─── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-real-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o
WHISPER_MODEL=whisper-1

# ─── Celery ───────────────────────────────────────────────────────────────────
CELERY_CONCURRENCY=2
